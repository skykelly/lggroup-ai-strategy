---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroCarousel from "../components/HeroCarousel.astro";
import StrategyRadar from "../components/StrategyRadar.astro";
import TopicCard from "../components/TopicCard.astro";
import { getTopics, THEME_META } from "../lib/content";

const topics = await getTopics();
const featured = topics.slice(0, 3);
const moreTopics = topics.slice(3, 9);
---

<BaseLayout>
  <section class="hero">
    <div class="hero-grid"></div>
    <div class="hero-content">
      <div class="hero-copy reveal">
        <span class="hero-kicker">LG Group AI Opportunity Research · 2026</span>
        <h1>
          AI가 산업을 바꿀 때,<br />
          <em>LG는 무엇을 장악해야 하는가.</em>
        </h1>
        <p>
          모델 경쟁 너머의 전력, 냉각, 제조, 모빌리티, 연구개발. 공개 출처와 18개의 전략 질문으로
          LG의 다음 사업기회를 추적합니다.
        </p>
        <div class="hero-actions">
          <a class="button primary" href="/insights">전략 질문 읽기</a>
          <a class="button text" href="#radar">6대 테마 탐색 <span>↓</span></a>
        </div>
      </div>
      <div class="hero-index reveal">
        <div><strong>06</strong><span>Opportunity themes</span></div>
        <div><strong>18</strong><span>Strategic questions</span></div>
        <div><strong>87</strong><span>Verified sources</span></div>
      </div>
    </div>
    <HeroCarousel />
  </section>

  <section class="section radar-section" id="radar">
    <div class="section-heading reveal">
      <span class="eyebrow">Strategy map</span>
      <h2>하나의 AI 전략이 아니라,<br />연결된 여섯 개의 산업 레이어</h2>
      <p>테마를 선택하면 LG의 사업 자산이 AI 가치사슬에서 어떤 역할을 갖는지 확인할 수 있습니다.</p>
    </div>
    <StrategyRadar />
  </section>

  <section class="section featured-section">
    <div class="section-heading horizontal reveal">
      <div>
        <span class="eyebrow">Featured insights</span>
        <h2>지금 먼저 읽어야 할 질문</h2>
      </div>
      <a class="section-link" href="/insights">18개 질문 전체 보기 <span>→</span></a>
    </div>
    <div class="featured-grid">
      {featured.map((topic, index) => <TopicCard topic={topic} featured={index === 0} />)}
    </div>
  </section>

  <section class="section themes-section" id="themes">
    <div class="section-heading reveal">
      <span class="eyebrow">Six opportunity fields</span>
      <h2>LG가 이미 가진 자산에서<br />AI 사업기회를 다시 읽습니다.</h2>
    </div>
    <div class="theme-list">
      {Object.entries(THEME_META).map(([id, theme]) => (
        <a class="theme-row reveal" href={`/insights?theme=${id}`} style={`--row-color:${theme.color}`}>
          <span class="theme-number">{theme.number}</span>
          <h3>{theme.title}</h3>
          <p>{theme.description}</p>
          <span class="theme-arrow">↗</span>
        </a>
      ))}
    </div>
  </section>

  <section class="section more-section">
    <div class="section-heading horizontal reveal">
      <div>
        <span class="eyebrow">Research journal</span>
        <h2>이어지는 전략 리서치</h2>
      </div>
    </div>
    <div class="topic-grid">
      {moreTopics.map((topic) => <TopicCard topic={topic} />)}
    </div>
  </section>

  <section class="closing-statement reveal">
    <p>AI 전략은 어떤 모델을 선택할지보다,<br /><strong>어떤 산업 지식을 남길지</strong>에서 시작합니다.</p>
    <a href="/insights">모든 인사이트 탐색 <span>→</span></a>
  </section>
  <script>
    const observer = new IntersectionObserver(
      (entries) => entries.forEach((entry) => entry.isIntersecting && entry.target.classList.add("visible")),
      { threshold: 0.12 }
    );
    document.querySelectorAll(".reveal").forEach((element) => observer.observe(element));
  </script>
</BaseLayout>
