---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SourceCard from "../../components/SourceCard.astro";
import { getSources, THEME_META } from "../../lib/content";

const sources = await getSources();
const publishers = [...new Set(sources.map((source) => source.publisher))].sort();
---

<BaseLayout title="Sources — LG AI Strategy Journal" description="LG AI 전략 리서치에 사용된 공개 출처와 근거 자료">
  <section class="source-list-hero">
    <div>
      <span class="eyebrow">Evidence ledger · {sources.length} sources</span>
      <h1>전략적 해석은<br /><em>검증 가능한 근거 위에.</em></h1>
      <p>기업 발표, 기관 보고서, 연구 논문과 언론 자료가 어떤 전략 질문과 연결되는지 추적합니다.</p>
    </div>
    <div class="evidence-index">
      <div><strong>{sources.length}</strong><span>Sources</span></div>
      <div><strong>{publishers.length}</strong><span>Publishers</span></div>
      <div><strong>06</strong><span>Themes</span></div>
    </div>
  </section>

  <section class="source-browser" data-source-browser>
    <div class="source-toolbar">
      <div>
        <button class="active" data-source-theme="all">전체</button>
        {Object.entries(THEME_META).map(([id, theme]) => <button data-source-theme={id}>{theme.short}</button>)}
      </div>
      <label><span class="sr-only">출처 검색</span><input type="search" placeholder="제목, 발행처 검색" data-source-search /></label>
    </div>
    <p class="result-count"><strong data-source-count>{sources.length}</strong>개의 공개 출처</p>
    <div class="source-grid">
      {sources.map((source) => (
        <div
          data-source-item
          data-themes={source.related_themes.join(" ")}
          data-search={`${source.title} ${source.publisher} ${source.tags.join(" ")}`.toLowerCase()}
        >
          <SourceCard source={source} />
        </div>
      ))}
    </div>
  </section>

  <script>
    const root = document.querySelector<HTMLElement>("[data-source-browser]");
    if (root) {
      const items = [...root.querySelectorAll<HTMLElement>("[data-source-item]")];
      const buttons = [...root.querySelectorAll<HTMLButtonElement>("[data-source-theme]")];
      const input = root.querySelector<HTMLInputElement>("[data-source-search]");
      const count = root.querySelector<HTMLElement>("[data-source-count]");
      let theme = "all";
      const apply = () => {
        const query = input?.value.trim().toLowerCase() || "";
        let visible = 0;
        items.forEach((item) => {
          const show = (theme === "all" || (item.dataset.themes || "").split(" ").includes(theme))
            && (!query || item.dataset.search?.includes(query));
          item.hidden = !show;
          if (show) visible += 1;
        });
        if (count) count.textContent = String(visible);
      };
      buttons.forEach((button) => button.addEventListener("click", () => {
        theme = button.dataset.sourceTheme || "all";
        buttons.forEach((item) => item.classList.toggle("active", item === button));
        apply();
      }));
      input?.addEventListener("input", apply);
    }
  </script>
</BaseLayout>
