{
  "name": "lg-ai-strategy-journal",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "set ASTRO_TELEMETRY_DISABLED=1&& astro dev",
    "score:topics": "python scripts/score_topic_priorities.py",
    "refresh:topics": "python scripts/score_topic_priorities.py && python scripts/generate_step8_indexes.py",
    "build": "node web/scripts/prepare-assets.mjs && set ASTRO_TELEMETRY_DISABLED=1&& astro build",
    "preview": "set ASTRO_TELEMETRY_DISABLED=1&& astro preview",
    "check": "set ASTRO_TELEMETRY_DISABLED=1&& astro check"
  },
  "dependencies": {
    "astro": "^6.4.8",
    "marked": "^16.1.1",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@types/node": "^24.0.0",
    "playwright-core": "^1.61.0",
    "typescript": "^5.8.3"
  }
}
