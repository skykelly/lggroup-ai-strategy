---
import BaseLayout from "../../layouts/BaseLayout.astro";
import EntityDetail from "../../components/EntityDetail.astro";
import { getCompanies, getConcepts, getTopics } from "../../lib/content";

export async function getStaticPaths() {
  const [concepts, companies, topics] = await Promise.all([getConcepts(), getCompanies(), getTopics()]);
  return concepts.map((entity) => ({
    params: { slug: entity.slug },
    props: {
      entity,
      relatedTopics: topics.filter((topic) => topic.related_concepts.includes(entity.slug)),
      relatedEntities: companies.filter((company) => entity.related_companies.includes(company.slug))
    }
  }));
}

const { entity, relatedTopics, relatedEntities } = Astro.props;
---

<BaseLayout title={`${entity.title} — LG AI Strategy Journal`} description={entity.summary} image={entity.heroImage}>
  <EntityDetail entity={entity} relatedTopics={relatedTopics} relatedEntities={relatedEntities} />
</BaseLayout>
