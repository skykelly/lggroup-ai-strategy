---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getThemes, THEME_META } from "../../lib/content";

const themes = await getThemes();
---

<BaseLayout title="Themes — LG AI Strategy Journal" description="LG그룹의 6대 AI 사업기회를 탐색합니다.">
  <section class="entity-list-hero">
    <span class="eyebrow">Six opportunity fields</span>
    <h1>여섯 개의 전장,<br /><em>LG가 장악할 수 있는 레이어.</em></h1>
    <p>모델 자체보다 AI가 실제 산업에서 작동하기 위해 필요한 인프라, 운영체계, 데이터와 파트너 생태계를 봅니다.</p>
  </section>
  <section class="theme-portfolio">
    {themes.map((theme) => {
      const meta = THEME_META[theme.slug as keyof typeof THEME_META];
      return (
        <a href={`/themes/${theme.slug}`} class="theme-portfolio-row" style={`--portfolio-color:${meta.color}`}>
          <span>{meta.number}</span>
          <div>
            <small>{meta.short}</small>
            <h2>{theme.title}</h2>
          </div>
          <p>{theme.summary}</p>
          <div class="portfolio-stats">
            <b>{theme.related_companies.length}</b><small>companies</small>
            <b>{theme.related_concepts.length}</b><small>concepts</small>
          </div>
          <i>↗</i>
        </a>
      );
    })}
  </section>
</BaseLayout>
