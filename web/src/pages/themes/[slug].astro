---
import BaseLayout from "../../layouts/BaseLayout.astro";
import EntityDetail from "../../components/EntityDetail.astro";
import { getCompanies, getConcepts, getThemes, getTopics } from "../../lib/content";

export async function getStaticPaths() {
  const [themes, topics, companies, concepts] = await Promise.all([getThemes(), getTopics(), getCompanies(), getConcepts()]);
  return themes.map((entity) => ({
    params: { slug: entity.slug },
    props: {
      entity,
      relatedTopics: topics.filter((topic) => topic.related_themes.includes(entity.slug as any)),
      relatedEntities: [
        ...companies.filter((company) => company.related_themes.includes(entity.slug as any)),
        ...concepts.filter((concept) => concept.primary_theme === entity.slug)
      ]
    }
  }));
}

const { entity, relatedTopics, relatedEntities } = Astro.props;
---

<BaseLayout title={`${entity.title} — LG AI Strategy Journal`} description={entity.summary} image={entity.heroImage}>
  <EntityDetail entity={entity} relatedTopics={relatedTopics} relatedEntities={relatedEntities} />
</BaseLayout>
