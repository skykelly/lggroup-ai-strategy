---
import BaseLayout from "../../layouts/BaseLayout.astro";
import EntityCard from "../../components/EntityCard.astro";
import { getCompanies } from "../../lib/content";

const companies = await getCompanies();
const affiliates = companies.filter((company) => company.category === "lg_affiliate");
const partners = companies.filter((company) => company.category === "partner");
---

<BaseLayout title="Companies — LG AI Strategy Journal" description="LG 계열사와 글로벌 파트너의 AI 전략 역할">
  <section class="entity-list-hero compact">
    <span class="eyebrow">Company map</span>
    <h1>기술이 아니라,<br /><em>누가 무엇을 맡는가.</em></h1>
    <p>각 회사의 일반적인 소개가 아니라 6대 AI 사업기회에서 확인된 역할, 자산, 파트너 의존도만 정리합니다.</p>
  </section>
  <section class="entity-browser" data-entity-browser>
    <div class="entity-toolbar">
      <div>
        <button class="active" data-category-filter="all">전체 {companies.length}</button>
        <button data-category-filter="lg_affiliate">LG 계열사 {affiliates.length}</button>
        <button data-category-filter="partner">Partners {partners.length}</button>
      </div>
      <label><span class="sr-only">회사 검색</span><input type="search" placeholder="회사명 검색" data-entity-search /></label>
    </div>
    <div class="entity-grid">
      {companies.map((company) => (
        <div data-entity-item data-category={company.category} data-search={company.title.toLowerCase()} data-themes={company.related_themes.join(" ")}>
          <EntityCard entity={company} href={`/companies/${company.slug}`} />
        </div>
      ))}
    </div>
  </section>
  <script>
    const browser = document.querySelector<HTMLElement>("[data-entity-browser]");
    if (browser) {
      const items = [...browser.querySelectorAll<HTMLElement>("[data-entity-item]")];
      const buttons = [...browser.querySelectorAll<HTMLButtonElement>("[data-category-filter]")];
      const input = browser.querySelector<HTMLInputElement>("[data-entity-search]");
      let category = "all";
      const apply = () => {
        const query = input?.value.trim().toLowerCase() || "";
        items.forEach((item) => item.hidden = !((category === "all" || item.dataset.category === category) && (!query || item.dataset.search?.includes(query))));
      };
      buttons.forEach((button) => button.addEventListener("click", () => {
        category = button.dataset.categoryFilter || "all";
        buttons.forEach((item) => item.classList.toggle("active", item === button));
        apply();
      }));
      input?.addEventListener("input", apply);
    }
  </script>
</BaseLayout>
